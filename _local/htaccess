Options -Indexes
ServerSignature Off
RewriteEngine on

# ── Block access to sensitive files ──
RewriteRule database\.js$ - [F,L]
RewriteRule cache\.json$ - [F,L]

# ── Clean URL: /ai → php/ai.php ──
RewriteRule ^ai$ /php/ai.php [L]

# ── Catch-all: route unknown paths to index.php (must be LAST) ──
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)$ index.php?page=$1 [QSA,L]

# php -- BEGIN cPanel-generated handler, do not edit
# This domain inherits the "PHP" package.
# php -- END cPanel-generated handler, do not edit

# ── Disable compression for SSE streaming ──
<IfModule mod_deflate.c>
  <FilesMatch "ai_stream\.php$">
    SetEnv no-gzip 1
    SetEnvIfNoCase Request_URI "\.php$" no-gzip
  </FilesMatch>
</IfModule>

<IfModule LiteSpeed>
  <FilesMatch "ai_stream\.php$">
    SetEnv no-gzip 1
  </FilesMatch>
</IfModule>
